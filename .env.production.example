# App
NODE_ENV=production
APP_PORT=3000
CORS_ORIGINS=https://payroll.your-domain.com
VITE_API_BASE_URL=https://payroll.your-domain.com/api

# MySQL
DB_HOST=mysql
DB_PORT=3306
DB_NAME=finance_payroll_prod
DB_USER=root
DB_PASSWORD=replace_this_strong_password
DATABASE_URL=mysql://root:replace_this_strong_password@mysql:3306/finance_payroll_prod

# File Storage
APP_DATA_DIR=.
UPLOAD_DIR=./uploads

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
